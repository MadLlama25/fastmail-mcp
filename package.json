{
  "name": "fastmail-mcp",
  "version": "1.12.0",
  "description": "MCP server for Fastmail API integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "fastmail-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "test": "tsx --test src/*.test.ts",
    "scan:secrets": "node scripts/scan-secrets.mjs --all"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "fastmail",
    "email",
    "jmap"
  ],
  "author": "Jeremy Gill",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "rrule": "^2.8.1",
    "tsdav": "^2.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
